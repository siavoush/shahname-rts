---
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Shahnameh Codex</title>
    <style>
      body { font-family: system-ui, -apple-system, sans-serif; max-width: 780px; margin: 2rem auto; padding: 0 1rem; line-height: 1.6; color: #1a1a1a; }
      header { margin-bottom: 1.5rem; }
      a { color: #7a1f2b; text-decoration: none; }
      a:hover { text-decoration: underline; }
      a.stub { color: #999; font-style: italic; }
      [dir="rtl"] { font-size: 1.15em; }
      blockquote { border-inline-start: 3px solid #c9a227; margin-inline: 0; padding-inline-start: 1rem; color: #333; }
      nav.sidebar { font-size: .9em; border-top: 1px solid #eee; margin-top: 2rem; padding-top: 1rem; }
      .tag { background: #f0ece0; border-radius: 4px; padding: .1rem .45rem; font-size: .8em; margin-inline-end: .35rem; }
      .stub { color: #999; font-style: italic; }
    </style>
  </head>
  <body>
    <header><a href="/">← Shahnameh Codex</a></header>
    <main><slot /></main>
  </body>
</html>
