; grain_cost = 0: same institutional coin-economy framing as Sowari-khaneh.
;
; construction_ticks = 960 = 32s @ 30Hz. Timing-ladder anchoring:
;   < Tirandazi(960=32s) < Sowari-khaneh(1080=36s) — lighter structure than
;   cavalry stable (training yard + range, not stalls + equipment). 2s above
;   Atashkadeh (900=30s) maintains the Tier-2 > Tier-1 distinction.
;
; max_hp = 650: lighter structure than Sowari-khaneh (750) — archery range
; is an open training ground, not a fortified stable. Still above Atashkadeh
; (600) since Tier-2 buildings warrant more durability than Tier-1.
;
; tier = 2: second first-non-default value of BuildingStats.tier (H3 dogfood).
; Same deferred-consumer chain as Sowari-khaneh above.
;
; Spec refs: 01_CORE_MECHANICS.md §5 (175 coin, Tier-2 table).
; balance-engineer: Wave 2B Track 3 — H3 + L6 inaugural dogfood.
[sub_resource type="Resource" id="bldg_tirandazi"]
script = ExtResource("3_bldgstats")
max_hp = 650.0
coin_cost = 175
grain_cost = 0
construction_ticks = 960
farr_per_tick = 0.0
farr_per_min_x100 = 0
population_capacity = 0
modifier_value_x100 = 0
modifier_radius_m = 0.0
modifier_stacks = false
tier = 2
; Wave 3A.6 training schema: Kamandar (UnitStats: coin=60, grain=15).
; Dwell 120 ticks = 4s per brief §1.
train_kamandar_cost_coin = 60
train_kamandar_cost_grain = 15
train_kamandar_dwell_ticks = 120

