; BalanceData.tres — canonical tunable gameplay numbers for Shahnameh RTS.
;
; Owned by: balance-engineer
; Loaded at: match start via Constants.PATH_BALANCE_DATA ("res://data/balance.tres")
; Schema: game/data/balance_data.gd + game/data/sub_resources/*.gd
; Spec references: 01_CORE_MECHANICS.md §3 §4 §5 §6 §9 + docs/AI_DIFFICULTY.md §1
;
; All numbers are STARTING POINTS to be tuned through playtesting.
; "Where numbers appear here, they are starting points to be tuned, not contracts."
; — 01_CORE_MECHANICS.md §0
;
; Phase 0 skeleton: kargar, piyade, kamandar + core buildings populated.
; Savar, asb_savar_kamandar, Rostam, and Tier-2 buildings ship when their
; phases land (Phase 1+ per 02_IMPLEMENTATION_PLAN.md).
;
; constants_version: manual stamp for this session. qa-engineer will wire
; file-hash auto-derivation in wave 2 (MatchHarness). See TESTING_CONTRACT.md §2.3.

[gd_resource type="Resource" script_class="BalanceData" load_steps=28 format=3 uid="uid://balance_data_main"]

[ext_resource type="Script" path="res://data/balance_data.gd" id="1_balancedata"]
[ext_resource type="Script" path="res://data/sub_resources/unit_stats.gd" id="2_unitstats"]
[ext_resource type="Script" path="res://data/sub_resources/building_stats.gd" id="3_bldgstats"]
[ext_resource type="Script" path="res://data/sub_resources/farr_config.gd" id="4_farrconfig"]
[ext_resource type="Script" path="res://data/sub_resources/combat_matrix.gd" id="5_combatmatrix"]
[ext_resource type="Script" path="res://data/sub_resources/economy_config.gd" id="6_economyconfig"]
[ext_resource type="Script" path="res://data/sub_resources/resource_node_config.gd" id="7_resnodeconfig"]
[ext_resource type="Script" path="res://data/sub_resources/ai_config.gd" id="8_aiconfig"]

; =========================================================================
; Unit stats sub-resources
; =========================================================================

; Kargar (worker) — 01_CORE_MECHANICS.md §6
; Fragile, minimal combat. Gathers resources, constructs buildings, repairs.
; HP: low (easily killed — reinforces the -1 Farr penalty when idle workers die).
; attack_damage_x100 = 0: workers cannot attack (CombatComponent skips 0-damage units).
[sub_resource type="Resource" id="unit_kargar"]
script = ExtResource("2_unitstats")
max_hp = 60.0
damage = 2.0
attack_speed_ticks = 60
attack_range = 0.0
move_speed = 3.5
population_cost = 1
coin_cost = 25
grain_cost = 0
production_ticks = 360
attack_damage_x100 = 0
attack_speed_per_sec = 1.0

; Piyade (foot infantry, Iran) — 01_CORE_MECHANICS.md §6
; Cheap, slow, durable. Spear-and-shield. Strong vs cavalry (> savar in RPS).
; Session-1 combat values: 1000 x100 damage = 10 dmg/hit; 6 hits to kill Kargar (60 HP).
; Piyade mirror combat: 100 HP ÷ (10 dmg × 1 hit/s) = 10s to resolve Piyade vs Piyade.
; RPS effectiveness multipliers ship in Phase 2 session 2; currently all matchups neutral.
[sub_resource type="Resource" id="unit_piyade"]
script = ExtResource("2_unitstats")
max_hp = 100.0
damage = 12.0
attack_speed_ticks = 30
attack_range = 1.5
move_speed = 2.5
population_cost = 1
coin_cost = 50
grain_cost = 10
production_ticks = 600
attack_damage_x100 = 1000
attack_speed_per_sec = 1.0

; Turan_Piyade (foot infantry, Turan) — mirror of Iran Piyade for Phase 2 session 1.
; Identical stats — RPS effectiveness matrix differentiating unit types ships in session 2.
; TODO: add Turan-specific RPS effectiveness in Phase 2 session 2 when full unit roster lands.
[sub_resource type="Resource" id="unit_turan_piyade"]
script = ExtResource("2_unitstats")
max_hp = 100.0
damage = 12.0
attack_speed_ticks = 30
attack_range = 1.5
move_speed = 2.5
population_cost = 1
coin_cost = 50
grain_cost = 10
production_ticks = 600
attack_damage_x100 = 1000
attack_speed_per_sec = 1.0

; Kamandar (Iran archer) — 01_CORE_MECHANICS.md §6, Phase 2 session 2 wave 1B
; Ranged infantry. Glass cannon — high per-hit damage, low HP, slow attack.
; RPS role: kamandar > piyade (archers shred infantry at range).
;           savar > kamandar (cavalry charges close range gap fast).
; attack_damage_x100 = 1500 → 15.0 dmg/hit at 0.7 attacks/sec = 10.5 DPS
; Kills Piyade (100 HP) in ~9.5s solo. Piyade kills Kamandar (60 HP) in 6.0s.
; With 1.5× matrix multiplier vs piyade: effective 1575 x100 = 22.5 DPS → Piyade dies ~4.4s
[sub_resource type="Resource" id="unit_kamandar"]
script = ExtResource("2_unitstats")
max_hp = 60.0
damage = 15.0
attack_speed_ticks = 43
attack_range = 8.0
move_speed = 2.5
population_cost = 1
coin_cost = 60
grain_cost = 15
production_ticks = 720
attack_damage_x100 = 1500
attack_speed_per_sec = 0.7

; Savar (Iran cavalry) — 01_CORE_MECHANICS.md §6, Phase 2 session 2 wave 1B
; Heavy mounted infantry. Tanky, fast, strong per-hit.
; RPS role: savar > kamandar (cavalry charge closes range quickly).
;           piyade > savar (massed spears stop horses — 0.7× savar vs piyade).
; attack_damage_x100 = 1200 → 12.0 dmg/hit at 0.9 attacks/sec = 10.8 DPS
; Kills Kamandar (60 HP) in ~5.6s but takes 2.0× multiplier damage from savar charge
[sub_resource type="Resource" id="unit_savar"]
script = ExtResource("2_unitstats")
max_hp = 150.0
damage = 12.0
attack_speed_ticks = 33
attack_range = 1.8
move_speed = 4.5
population_cost = 1
coin_cost = 75
grain_cost = 20
production_ticks = 900
attack_damage_x100 = 1200
attack_speed_per_sec = 0.9

; Asb-savar Kamandar (Iran horse archer) — 01_CORE_MECHANICS.md §6, Phase 2 session 2 wave 1B
; Combined mounted archer. Mobile, ranged, but vulnerable to sustained melee.
; RPS role: asb_savar_kamandar has 1.2× vs piyade (kiting); 0.5× vs savar (outrun but can't
;           outlast sustained cavalry engagement); neutral vs kamandar foot archers.
; attack_damage_x100 = 1300 → 13.0 dmg/hit at 0.6 attacks/sec = 7.8 DPS
; Tier 1-equivalent — rebalanced upward when Tier 2 tech ships (Phase 4).
; Kiting AI (move-fire-move) NOT in session 2; deferred to Phase 6 DummyAIController.
[sub_resource type="Resource" id="unit_asb_savar_kamandar"]
script = ExtResource("2_unitstats")
max_hp = 100.0
damage = 13.0
attack_speed_ticks = 50
attack_range = 7.0
move_speed = 4.0
population_cost = 1
coin_cost = 80
grain_cost = 20
production_ticks = 1080
attack_damage_x100 = 1300
attack_speed_per_sec = 0.6

