tier2_threshold = 40.0
kaveh_trigger_threshold = 15.0
kaveh_grace_ticks = 900
kaveh_farr_lock_ticks = 1800
kaveh_resolve_threshold = 30.0
kaveh_resolve_window_ticks = 2700
drain_idle_worker_killed = -1.0
drain_hero_attack_ally = -5.0
drain_hero_killed_fleeing = -10.0
drain_hero_killed_battle = -5.0
drain_atashkadeh_lost = -5.0
drain_snowball_per_kill = -0.5
drain_snowball_worker = -1.0
snowball_ratio = 3.0
gain_hero_rescue = 3.0
gain_hero_spares_enemy = 5.0
; Phase 3 wave 1B drain-rate table (Open Space 2026-05-13 resolution).
; Positive magnitudes; the dispatcher applies the negative sign at the call site.
; Phase 3 wired keys: worker_killed_idle, worker_killed_during_gather.
; Forward-compat keys (Phase 4+ emit sites): capital_damaged, capital_lost,
; building_destroyed_civilian, building_destroyed_military,
; building_destroyed_atashkadeh, hero_died.
drain_rates = {
&"worker_killed_idle": 1.0,
&"worker_killed_during_gather": 0.5,
&"capital_damaged": 2.0,
&"capital_lost": 12.0,
&"building_destroyed_civilian": 1.5,
&"building_destroyed_military": 2.5,
&"building_destroyed_atashkadeh": 5.0,
&"hero_died": 5.0
}

; =========================================================================
; CombatMatrix sub-resource
; =========================================================================
; status: calibrated — RPS triangle direction anchored to spec (§6). Multiplier
;   magnitudes (1.5×, 2.0×, 0.7×, 0.5×) derived from Wave-2B session-2 kickoff
;   §2 + DPS math comments. "All values are starting points; lead tunes via this
;   file without code changes." AI-vs-AI army matchup validation pending.
; Rock-paper-scissors triangle: piyade > savar > kamandar > piyade
; 01_CORE_MECHANICS.md §6: "piyade > savar > kamandar > piyade"
;
; Multiplier key: attacker_type -> defender_type -> float
; 1.0 = neutral, 1.5 = advantage, 0.67 ≈ disadvantage
;
; Phase 0 skeleton: only the three Tier-1 unit types populated.
; Savar and asb_savar_kamandar filled in when Phase 1+ units ship.
;
; Edge pairs not listed default to 1.0 (neutral) in CombatSystem.
;
; Note: Godot .tres format stores nested Dictionaries. The outer key is
; attacker StringName, inner dict maps defender StringName to float.

[sub_resource type="Resource" id="combat_mtx"]
script = ExtResource("5_combatmatrix")
; Rock-paper-scissors effectiveness matrix — Phase 2 session 2 wave 1B
; Source: 02e_PHASE_2_SESSION_2_KICKOFF.md §2 item 5
; Spec: 01_CORE_MECHANICS.md §6 "piyade > savar > kamandar > piyade"
;
; Only Iran base-type rows are stored (4×4 = 16 cells).
; Turan mirror types fold at lookup time via CombatMatrix.get_multiplier()
; which strips the "turan_" prefix — see combat_matrix.gd for details.
;
; Row interpretation (attacker → target):
;   piyade:             neutral vs piyade, neutral vs kamandar, 1.5× vs savar (anti-cav), neutral vs asb-savar
;   kamandar:           1.5× vs piyade (archers vs infantry), neutral vs kamandar, 0.7× vs savar (can't stop charge), 0.7× vs asb-savar
;   savar:              0.7× vs piyade (spears stop horses), 2.0× vs kamandar (decisive cavalry charge), neutral vs savar, neutral vs asb-savar
;   asb_savar_kamandar: 1.2× vs piyade (kiting), neutral vs kamandar, 0.5× vs savar (outrun but can't outlast), neutral vs asb-savar
;
; Design rationale:
;   1.5× piyade>savar: 5 Piyade vs 5 Savar should converge in ~8s (Piyade wins).
;   2.0× savar>kamandar: decisive cavalry charge; Savar wins even with fewer numbers.
;   1.5× kamandar>piyade: archers at range shred slow infantry; range gate required.
;   0.5× asb_savar>savar: horse archers can kite but lose prolonged melee vs heavy cav.
;   All values are starting points; lead tunes via this file without code changes.
effectiveness = {
&"piyade": {
&"piyade": 1.0,
&"kamandar": 1.0,
&"savar": 1.5,
&"asb_savar_kamandar": 1.0
},
&"kamandar": {
&"piyade": 1.5,
&"kamandar": 1.0,
&"savar": 0.7,
&"asb_savar_kamandar": 0.7
},
&"savar": {
&"piyade": 0.7,
&"kamandar": 2.0,
&"savar": 1.0,
&"asb_savar_kamandar": 1.0
},
&"asb_savar_kamandar": {
&"piyade": 1.2,
&"kamandar": 1.0,
&"savar": 0.5,
&"asb_savar_kamandar": 1.0
}
}

; =========================================================================
; ResourceNodeConfig sub-resource
; =========================================================================
; Values from RESOURCE_NODE_CONTRACT.md §7.
; status: anchored — mine_initial_stock, mine_max_workers, coin yields, and
;   trip_full_load_ticks derived from RESOURCE_NODE_CONTRACT.md §7 SSOT;
;   should only change if RNC §7 changes. EXCEPTION grain_yield_per_trip = 2:
;   Room A Open Space resolution (2026-05-14, 02g §2.4 — "grain_yield_per_
;   trip_x100 = 200 (2 Grain/trip)") postdates and supersedes the RNC §7
;   draft value (8). Folded into the .tres at the 2026-06-08 SSOT fix
;   (wave/b1-mine-ssot) so the now-live key matches shipped behavior —
;   pre-fix, mazraeh.gd hardcoded 200 x100 and this key was dormant.
;   RNC §7 prose reconciliation queued for the contract owner.
;
; LIVE as of wave/b1-mine-ssot (2026-06-08): MineNode reads mine_initial_
; stock, mine_max_workers, coin_yield_per_trip, trip_full_load_ticks;
; Mazra'eh reads grain_yield_per_trip, farm_max_workers. Mazra'eh dwell
; (90 ticks, Room A cultural long-dwell) remains code-side — the shared
; trip_full_load_ticks cannot express the ratified per-kind split; a
; farm-specific dwell key is queued for the next schema pass.

[sub_resource type="Resource" id="res_node_cfg"]
script = ExtResource("7_resnodeconfig")
mine_initial_stock = 1500
mine_max_workers = 2
coin_yield_per_trip = 10
coin_yield_per_tick = 1
grain_yield_per_trip = 2
grain_yield_per_tick = 1
farm_max_workers = 1
trip_full_load_ticks = 60

