[gd_scene load_steps=5 format=3 uid="uid://shahnameh_piyade_unit"]

; piyade.tscn — Piyade (Iran foot infantry) scene.
;
; Source: 01_CORE_MECHANICS.md §6 — "Piyade (foot infantry) — cheap, slow,
; durable. Spear-and-shield. Strong vs cavalry (> savar in RPS triangle)."
;
; Pattern: scene inheritance via instance=ExtResource("path_to_unit.tscn").
; Same shape as kargar.tscn — overrides only the MeshInstance3D's mesh +
; material plus the root's script. CombatComponent etc. all inherit from
; the unit.tscn template.
;
; Visual placeholder per CLAUDE.md "colored shapes only" policy:
;   - Box (cube), 0.5 wide × 0.7 tall × 0.5 deep — slightly taller than
;     the Kargar cylinder (0.7 tall, 0.7 wide) so the silhouettes are
;     distinguishable at default isometric camera distance. Piyade is
;     "narrower and taller — soldier silhouette" vs. Kargar's "squat
;     hunched worker."
;   - Iran-blue color (Color(0.3, 0.4, 0.7) — saturated blue distinct
;     from the unit.tscn default blue-grey (0.3, 0.5, 0.7) AND from the
;     Kargar sandy brown (0.65, 0.5, 0.3). Forms the visual half of the
;     Iran-vs-Turan team split — Turan_Piyade ships at the same time
;     in Turan-red (0.7, 0.3, 0.3).

[ext_resource type="PackedScene" uid="uid://shahnameh_unit_base" path="res://scenes/units/unit.tscn" id="1_unit_template"]
[ext_resource type="Script" path="res://scripts/units/piyade.gd" id="2_piyade"]

[sub_resource type="BoxMesh" id="BoxMesh_piyade"]
; Iran soldier silhouette: a slightly taller cube than the base unit's
; 0.5 × 0.6 × 0.5. The +0.1 height differentiates Piyade from any future
; cube-based worker / specialist while staying compact enough to read
; cleanly at default zoom.
size = Vector3(0.5, 0.7, 0.5)

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_piyade"]
; Iran blue. Saturated enough to read against the sandy terrain without
; clashing with the Kargar's earth-tone or the future Turan-red of
; turan_piyade.tscn. CLAUDE.md placeholder policy — pick a color that
; communicates "Iran combat unit" at a glance.
albedo_color = Color(0.3, 0.4, 0.7, 1.0)
shading_mode = 2 ; SHADING_MODE_PER_PIXEL — same simple lit pipeline as
                  ; the rest of the placeholder units; consistency over
                  ; fanciness for placeholders.


; Inherit the Unit scene template; override only what differs.
[node name="Piyade" instance=ExtResource("1_unit_template")]
script = ExtResource("2_piyade")

[node name="MeshInstance3D" parent="." index="0"]
; Override the base Unit's BoxMesh (0.5×0.6×0.5) with the Piyade's
; slightly-taller box (0.5×0.7×0.5). Y-offset matches half-height (0.35)
; so the mesh-bottom sits ON the terrain plane (consistent with the
; unit.tscn convention).
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.35, 0)
mesh = SubResource("BoxMesh_piyade")
material_override = SubResource("StandardMaterial3D_piyade")
