[gd_scene load_steps=2 format=3 uid="uid://shahfarrlogoverlay"]

; farr_log_overlay.tscn — Phase 4 wave 1 (gameplay-systems).
;
; F2 debug overlay: a floating on-screen log of every Farr change (CLAUDE.md
; mandate "every Farr change as a floating log"). The reserved F2 slot
; (DebugOverlayManager) was a logged no-op since Phase 0; this wave wires it.
;
; Implementation choice (documented in the script): Control + RichTextLabel,
; NOT Node3D — DebugOverlayManager.register_overlay is statically typed against
; Control. The script self-builds its RichTextLabel child in _ready so the
; overlay needs no scene-author handoff (matches the .new()-decouple pattern).
;
; CRITICAL: mouse_filter MUST be MOUSE_FILTER_IGNORE (= 2). Pitfall #1.
; visible = false by default — F2 keypress is the only show-path.

[ext_resource type="Script" path="res://scripts/ui/overlays/farr_log_overlay.gd" id="1_farrlog"]

[node name="FarrLogOverlay" type="Control"]
visible = false
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
script = ExtResource("1_farrlog")
