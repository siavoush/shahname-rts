[gd_scene load_steps=2 format=3 uid="uid://shahnameh_build_menu"]

; build_menu.tscn — bottom-right HUD panel for placing buildings.
;
; Phase 3 session 1 wave 1C deliverable 5. Per
; 02f_PHASE_3_KICKOFF.md §3 wave 1C.
;
; Layout:
;   CanvasLayer (BuildMenu)
;     └── Root (Control, anchored bottom-right, hidden by default)
;         ├── Background (ColorRect, fills root)
;         └── Margin (MarginContainer, padded)
;             └── VBox (VBoxContainer)
;                 ├── HeaderLabel ("Build")
;                 ├── KhanehButton ("Khaneh (50 Coin)")
;                 ├── MazraehButton ("Mazra'eh (60 Coin)") — wave 1A late-add.
;                 │   Agricultural-green tint distinguishes from Khaneh's
;                 │   earthy tan.
;                 ├── MadanButton ("Ma'dan (40 Coin)") — wave 1B late-add
;                 │   bundled with the building scene per the wave-1A
;                 │   late-add lesson. Stone-grey/metal tint distinguishes
;                 │   from Khaneh/Mazra'eh.
;                 ├── SarbazKhanehButton ("Sarbaz-khaneh (100 Coin)") —
;                 │   wave 2A. Martial-red tint — barracks / training.
;                 ├── AtashkadehButton ("Atashkadeh (150 Coin / 50 Grain)")
;                 │   — wave 2A.5. Fire-amber tint — sacred-flame
;                 │   container. Tier-1 closure and Tier-2 gateway.
;                 ├── SowariKhanehButton ("Sowari-khaneh (200 Coin)") —
;                 │   wave 2B. Cavalry-blue-grey tint — cavalry stable,
;                 │   Tier-2 first entry. Produces Savar.
;                 └── TirandaziButton ("Tirandazi (175 Coin)") —
;                     wave 2B. Arrow-fletch-brown tint — archery range,
;                     Tier-2 first entry. Produces advanced Kamandar.
;                     Order is chronological: Khaneh → Mazra'eh → Ma'dan
;                     → Sarbaz-khaneh → Atashkadeh → Sowari-khaneh →
;                     Tirandazi.
;
; Pitfall #1 mitigation + BUG-08 fix — mouse_filter discipline:
;   - Root: MOUSE_FILTER_STOP (value 0). BUG-08 fix — the entire menu
;     surface is an input shield. Clicks within the menu rect never
;     fall through to _unhandled_input regardless of the Button's
;     action_mode default (ACTION_MODE_BUTTON_RELEASE). Before this
;     fix, the PRESS edge of a click on the button leaked to
;     ClickHandler's _unhandled_input + BPH's _unhandled_input,
;     triggering deselect-all-on-empty-terrain (since BPH's
;     _placement_kind == &"" at PRESS — placement mode is only entered
;     on RELEASE when the Button's pressed signal fires). Result:
;     selection wiped before placement mode begins, menu hides itself,
;     ghost ends up orphaned. STOP at Root blocks the PRESS edge.
;   - Background, Margin, VBox, HeaderLabel: MOUSE_FILTER_PASS (value 1).
;     Decorative children — clicks layer inward to the Button. Only the
;     Root needs to be a shield; children pass through.
;   - KhanehButton: MOUSE_FILTER_STOP (value 0, the Button default —
;     omitting the override is intentional so the click reliably
;     lands on the button itself).
;
; Visibility:
;   The Root Control starts visible = false. build_menu.gd's _ready also
;   asserts this defensively, and the EventBus.selection_changed handler
;   flips it on/off based on whether the selection contains a Kargar.
;
; Internationalization: every visible string flows through tr() in the
; script. The .tscn placeholder text is the development-time fallback;
; runtime always wins.

[ext_resource type="Script" path="res://scripts/ui/build_menu.gd" id="1_buildmenu"]


[node name="BuildMenu" type="CanvasLayer"]
script = ExtResource("1_buildmenu")

[node name="Root" type="Control" parent="."]
; Anchored bottom-right. Width 200, height 120 — small panel, two-line
; layout: header + one button per available building (Khaneh in
; session 1; session 2 adds Mazra'eh / etc. and the height grows).
visible = false
anchors_preset = 3 ; PRESET_BOTTOM_RIGHT
anchor_left = 1.0
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = -216.0
offset_top = -386.0
offset_right = -16.0
offset_bottom = -66.0
mouse_filter = 0 ; MOUSE_FILTER_STOP — BUG-08 fix; menu surface is a click shield.
grow_horizontal = 0
grow_vertical = 0

[node name="Background" type="ColorRect" parent="Root"]
anchors_preset = 15 ; PRESET_FULL_RECT
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 1 ; PASS — decorative.
color = Color(0.1, 0.1, 0.12, 0.75)

[node name="Margin" type="MarginContainer" parent="Root"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 1 ; PASS — decorative container.
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="Root/Margin"]
layout_mode = 2
mouse_filter = 1 ; PASS — decorative container.
theme_override_constants/separation = 8

[node name="HeaderLabel" type="Label" parent="Root/Margin/VBox"]
layout_mode = 2
mouse_filter = 1 ; PASS — decorative label.
text = "Build"
horizontal_alignment = 1 ; HORIZONTAL_ALIGNMENT_CENTER

[node name="KhanehButton" type="Button" parent="Root/Margin/VBox"]
; The actual interactive element. MOUSE_FILTER_STOP (Button default,
; not overridden) so the click lands on the button itself.
; build_menu.gd connects .pressed in _ready.
layout_mode = 2
text = "Khaneh (50 Coin)"

[node name="MazraehButton" type="Button" parent="Root/Margin/VBox"]
; Wave 1A late-add — the Mazra'eh placement entry point. Same
; MOUSE_FILTER_STOP default as KhanehButton. Agricultural-green hint
; (0.45, 0.55, 0.30) — a darker, plant-tinted variant of the Mazra'eh
; scene's field color (0.55, 0.75, 0.35) so the button reads as related
; to the field placeholder without being so bright it overwhelms the
; dark HUD palette.
layout_mode = 2
text = "Mazra'eh (60 Coin)"
self_modulate = Color(0.45, 0.55, 0.30, 1.0)

[node name="MadanButton" type="Button" parent="Root/Margin/VBox"]
; Wave 1B — the Ma'dan placement entry point. Same MOUSE_FILTER_STOP
; default as the other buttons. Stone-grey hint (0.55, 0.55, 0.55) —
; a darker, neutral-tone variant of the Ma'dan scene's industrial-grey
; color (0.5, 0.5, 0.55) so the button reads as related to the building
; without overwhelming the dark HUD. The button's "metal/iron" tint
; (slight B-channel weight vs RG) carries the same coding as the scene.
;
; build_menu.gd connects .pressed in _ready (mirrors KhanehButton /
; MazraehButton wire-up). The button emits build_placement_started with
; Madan.KIND_MADAN + cost_x100 to enter placement mode.
layout_mode = 2
text = "Ma'dan (40 Coin)"
self_modulate = Color(0.55, 0.55, 0.60, 1.0)

[node name="SarbazKhanehButton" type="Button" parent="Root/Margin/VBox"]
; Wave 2A — the Sarbaz-khaneh (barracks) placement entry point. Same
; MOUSE_FILTER_STOP default as the other buttons. Martial-red tint
; (0.65, 0.30, 0.25) — oxidized-iron / blood-rust hue signalling the
; military / training role. Distinct from Khaneh's earthy tan,
; Mazra'eh's agricultural green, Ma'dan's industrial grey. The colour
; reads as "soldiers / armed force" at a glance without overpowering
; the dark HUD palette.
;
; build_menu.gd connects .pressed in _ready (mirrors prior buttons).
; The button emits build_placement_started with
; SarbazKhaneh.KIND_SARBAZ_KHANEH + cost_x100 to enter placement mode.
layout_mode = 2
text = "Sarbaz-khaneh (100 Coin)"
self_modulate = Color(0.65, 0.30, 0.25, 1.0)

[node name="AtashkadehButton" type="Button" parent="Root/Margin/VBox"]
; Wave 2A.5 — the Atashkadeh (sacred-flame container) placement entry
; point. Tier-1 closure (5th and final Tier-1 building) and Tier-2
; gateway. Per 01_CORE_MECHANICS.md §5 the cost is dual-resource
; (150 coin + 50 grain), so the label format is
; "Atashkadeh (%d Coin / %d Grain)" — the only Tier-1 button with a
; dual-cost surface. Same MOUSE_FILTER_STOP default as the other
; buttons. Fire-amber tint (0.85, 0.65, 0.20) — warm sacred-flame
; hue distinct from Khaneh's earthy tan, Mazra'eh's agricultural
; green, Ma'dan's industrial grey, Sarbaz-khaneh's martial-red.
;
; The signal payload (build_placement_started) carries ONLY
; cost_coin_x100 by contract (EventBus.build_placement_started
; signature locked at coin-only). The 50 grain is deducted at
; placement time inside UnitState_Constructing — the UI surface
; shows both costs in the label, but the dispatch signal carries
; one. Same UI vs sim-side separation as the other buttons.
layout_mode = 2
text = "Atashkadeh (150 Coin / 50 Grain)"
self_modulate = Color(0.85, 0.65, 0.20, 1.0)

[node name="SowariKhanehButton" type="Button" parent="Root/Margin/VBox"]
; Wave 2B — the Sowari-khaneh (cavalry stable, lit. 'rider-house')
; placement entry point. Iran Tier-2 first entry. Per
; 01_CORE_MECHANICS.md §5 the cost is coin-only (200 coin, no grain),
; so the label format mirrors the Sarbaz-khaneh single-cost shape
; ("Sowari-khaneh (%d Coin)"). Same MOUSE_FILTER_STOP default as the
; other buttons. Cavalry-blue-grey tint (0.35, 0.42, 0.55) — saddle-
; leather + horse-hide hue distinct from Sarbaz-khaneh's martial-red
; and Atashkadeh's fire-amber. The "blue-grey for cavalry" follows
; the unit-mesh convention (Savar inherits Iran blue).
;
; Loremaster J3 tooltip framing — "Cavalry training stable
; (lit. 'rider-house')." carries the literal-first compound gloss
; per loremaster Track 0 J3 review of سواری‌خانه (sowari = riding,
; -khaneh = house). The "rider-house" literal is the cultural
; primary; "cavalry stable" is the disambiguating English context.
layout_mode = 2
text = "Sowari-khaneh (200 Coin)"
self_modulate = Color(0.35, 0.42, 0.55, 1.0)

[node name="TirandaziButton" type="Button" parent="Root/Margin/VBox"]
; Wave 2B — the Tirandazi (archery range, lit. 'arrow-shooting
; practice') placement entry point. Iran Tier-2 first entry. Per
; 01_CORE_MECHANICS.md §5 the cost is coin-only (175 coin, no grain).
; Same MOUSE_FILTER_STOP default. Arrow-fletch-brown tint
; (0.55, 0.42, 0.28) — wood-shaft + leather-quiver hue, distinct
; from Sowari-khaneh's cavalry-blue-grey.
;
; Loremaster J3 tooltip framing — "Archery training ground
; (lit. 'arrow-shooting practice')." Honors loremaster Track 0 J3
; verdict on تیراندازی: the verbal-noun "tir-andazi" (tir = arrow,
; andazi = throwing/shooting) glosses literally to the action of
; archery practice, NOT to a recreational "archery range" (the
; tricky-gloss carries modern sport-shooting register baggage).
;
; Loremaster J4 (l) constraint: NO mention of Arash or other
; hero-mythological archer figures here — conflating institutional-
; ordinary archer-production with hero-mythological Arash-the-Archer
; is the J4 named anti-pattern. Tooltip stays ordinary-institutional.
layout_mode = 2
text = "Tirandazi (175 Coin)"
self_modulate = Color(0.55, 0.42, 0.28, 1.0)
