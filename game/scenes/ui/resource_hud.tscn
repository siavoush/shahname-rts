[gd_scene load_steps=3 format=3 uid="uid://b7shahresourcehud01"]

[ext_resource type="Script" path="res://scripts/ui/resource_hud.gd" id="1_hud"]
[ext_resource type="PackedScene" uid="uid://b7shahfarrgauge01" path="res://scenes/ui/farr_gauge.tscn" id="2_gauge"]

[node name="ResourceHUD" type="CanvasLayer"]
script = ExtResource("1_hud")

; Dark backdrop shelf for the top HUD. Lead live-test #2 surfaced
; readability issues — white text on sandy terrain has poor contrast.
; A dark ColorRect with alpha 0.65 reads through to the world but
; ensures the labels (Coin / Grain / Pop / Farr) are legible at any
; zoom level. The shelf is full-width so it visually anchors the top
; of the screen as a proper HUD strip — future top-HUD additions
; (tech-tier indicator, victory progress, etc.) plug into the same
; backdrop without re-doing the contrast pass. Drawn FIRST (before
; Margin in scene-tree order) so labels render on top.
[node name="Background" type="ColorRect" parent="."]
anchors_preset = 10 ; PRESET_TOP_WIDE
anchor_right = 1.0
offset_bottom = 80.0
grow_horizontal = 2
mouse_filter = 2 ; IGNORE — backdrop never consumes clicks (Pitfall #1)
color = Color(0.08, 0.08, 0.1, 0.65)

[node name="Margin" type="MarginContainer" parent="."]
anchors_preset = 10
anchor_right = 1.0
offset_bottom = 80.0
grow_horizontal = 2
mouse_filter = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 8

[node name="HBox" type="HBoxContainer" parent="Margin"]
layout_mode = 2
mouse_filter = 2
theme_override_constants/separation = 24

[node name="CoinLabel" type="Label" parent="Margin/HBox"]
layout_mode = 2
mouse_filter = 2
text = "Coin: 0"

[node name="GrainLabel" type="Label" parent="Margin/HBox"]
layout_mode = 2
mouse_filter = 2
text = "Grain: 0"

[node name="PopLabel" type="Label" parent="Margin/HBox"]
layout_mode = 2
mouse_filter = 2
text = "Pop: 0/0"

[node name="Spacer" type="Control" parent="Margin/HBox"]
layout_mode = 2
size_flags_horizontal = 3
mouse_filter = 2

[node name="FarrGauge" parent="Margin/HBox" instance=ExtResource("2_gauge")]
layout_mode = 2
